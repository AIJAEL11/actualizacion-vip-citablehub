# ===========================================
# CitableHub Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Database
DATABASE_URL="postgresql://user:password@host:5432/citablehub?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret-here"

# Abacus AI (LLM API)
ABACUSAI_API_KEY="your-abacusai-api-key"

# Google OAuth (SSO)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Google Analytics (optional)
NEXT_PUBLIC_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"

# Stripe (Payments for GQI Boost)
STRIPE_SECRET_KEY="sk_live_or_sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_or_pk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# AWS S3 (File uploads)
AWS_PROFILE="default"
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="your-bucket-name"
AWS_FOLDER_PREFIX="citablehub"

# App ID (internal)
WEB_APP_ID=""

# Notification IDs (generated by platform)
NOTIF_ID_PROFILE_COMPLETENESS_REMINDER=""
NOTIF_ID_RANKING_MOVEMENT_ALERT=""
NOTIF_ID_CITABILITY_SCORE_UPDATE=""
NOTIF_ID_BOOST_BENEFITS_INFO=""
NOTIF_ID_WEEKLY_PERFORMANCE_DIGEST=""
NOTIF_ID_CONTACT_FORM_SUBMISSION=""

# IndexNow (SEO instant indexing)
INDEXNOW_KEY="your-indexnow-key"

# Admin email (gets admin role on signup/login)
ADMIN_EMAIL="your-admin-email@example.com"
